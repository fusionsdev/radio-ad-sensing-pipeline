{
  "annotations": {
    "list": []
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "id": 1,
      "title": "Queue depth (pending hours)",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "pipeline_queue_pending_hours",
          "refId": "A",
          "legendFormat": "pending hours"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 3600},
              {"color": "red", "value": 7200}
            ]
          }
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": {"calcs": ["lastNotNull"]}
      }
    },
    {
      "id": 2,
      "title": "Chunks processed / hour (by service)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 6, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "sum by (service) (rate(pipeline_chunks_processed_total[1h]) * 3600)",
          "refId": "A",
          "legendFormat": "{{service}}"
        }
      ],
      "fieldConfig": {
        "defaults": {"unit": "short", "custom": {"drawStyle": "line", "lineWidth": 2}}
      },
      "options": {"legend": {"displayMode": "table", "placement": "right"}}
    },
    {
      "id": 3,
      "title": "Chunks dropped / 10m",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 6, "x": 18, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "sum(rate(pipeline_chunks_dropped_total[10m])) * 600",
          "refId": "A",
          "legendFormat": "dropped"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "short", "color": {"mode": "fixed", "value": "red"}}}
    },
    {
      "id": 4,
      "title": "ASR real-time factor (lower is faster)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "pipeline_asr_rtf_avg",
          "refId": "A",
          "legendFormat": "RTF avg"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "custom": {"drawStyle": "line", "lineWidth": 2},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 0.5},
              {"color": "red", "value": 1.0}
            ]
          }
        }
      }
    },
    {
      "id": 5,
      "title": "LLM extraction latency (p50 / p95)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(pipeline_llm_extraction_duration_seconds_bucket[5m])) by (le))",
          "refId": "A",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(pipeline_llm_extraction_duration_seconds_bucket[5m])) by (le))",
          "refId": "B",
          "legendFormat": "p95"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "s"}}
    },
    {
      "id": 6,
      "title": "Detections / hour",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "sum(rate(pipeline_detections_total[1h])) * 3600",
          "refId": "A",
          "legendFormat": "detections"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "short", "color": {"mode": "fixed", "value": "blue"}}}
    },
    {
      "id": 7,
      "title": "Station uptime (last chunk ago)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 16},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "time() - pipeline_station_last_chunk_timestamp_seconds",
          "refId": "A",
          "legendFormat": "{{station}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {"drawStyle": "line", "lineWidth": 2},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 600},
              {"color": "red", "value": 900}
            ]
          }
        }
      },
      "options": {"legend": {"displayMode": "table", "placement": "right"}}
    },
    {
      "id": 8,
      "title": "GPU utilization (DCGM)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 24},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "DCGM_FI_DEV_GPU_UTIL",
          "refId": "A",
          "legendFormat": "gpu{{gpu}} util"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100
        }
      }
    },
    {
      "id": 9,
      "title": "GPU memory used (DCGM)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 24},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "DCGM_FI_DEV_FB_USED",
          "refId": "A",
          "legendFormat": "gpu{{gpu}} used"
        },
        {
          "expr": "DCGM_FI_DEV_FB_USED + DCGM_FI_DEV_FB_FREE",
          "refId": "B",
          "legendFormat": "gpu{{gpu}} total"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "bytes"}}
    },
    {
      "id": 10,
      "title": "Active alerts",
      "type": "stat",
      "gridPos": {"h": 4, "w": 24, "x": 0, "y": 32},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "count(ALERTS{alertstate=\"firing\"})",
          "refId": "A",
          "legendFormat": "firing"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "red", "value": 1}
            ]
          }
        }
      }
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "style": "dark",
  "tags": ["radio", "pipeline"],
  "templating": {"list": []},
  "time": {"from": "now-6h", "to": "now"},
  "timepicker": {},
  "timezone": "",
  "title": "Radio Ad-Sensing Pipeline",
  "uid": "radio-pipeline",
  "version": 1,
  "weekStart": ""
}

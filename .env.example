# Telegram Bot API (outbound alerts only)
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Grafana admin (set non-default before exposing beyond localhost)
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# Dashboard binding for local `python -m dashboard` only.
# Docker compose always sets DASHBOARD_HOST=0.0.0.0 inside the container.
DASHBOARD_HOST=127.0.0.1
DASHBOARD_PORT=8080

# Optional HTTP Basic auth for the dashboard. Leave unset for the LAN-only
# default (no auth). Set BOTH to require credentials on every route except
# /health — strongly recommended whenever the dashboard is reachable beyond
# localhost (e.g. DASHBOARD_HOST=0.0.0.0 in the container).
# DASHBOARD_BASIC_AUTH_USER=ops
# DASHBOARD_BASIC_AUTH_PASSWORD=change_me

# Transient chunk WAV storage (set by docker-compose on GPU host)
# CHUNKS_DIR=/app/chunks

# Worker ASR (docker-compose.prod.yml passes these into radio-worker)
# Windows dev: docker-compose.windows-dev.yml disables GPU — use int8 on CPU
# ASR_MODEL=medium.en
# ASR_COMPUTE_TYPE=int8

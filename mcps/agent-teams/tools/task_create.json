{
  "name": "task_create",
  "description": "Create a team task",
  "inputSchema": {
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "object",
    "properties": {
      "teamName": {
        "type": "string",
        "minLength": 1
      },
      "claudeDir": {
        "type": "string",
        "minLength": 1
      },
      "subject": {
        "type": "string",
        "minLength": 1
      },
      "description": {
        "type": "string"
      },
      "owner": {
        "type": "string"
      },
      "createdBy": {
        "type": "string"
      },
      "from": {
        "type": "string"
      },
      "blockedBy": {
        "type": "array",
        "items": {
          "type": "string",
          "minLength": 1
        }
      },
      "related": {
        "type": "array",
        "items": {
          "type": "string",
          "minLength": 1
        }
      },
      "prompt": {
        "type": "string"
      },
      "startImmediately": {
        "type": "boolean"
      }
    },
    "required": [
      "teamName",
      "subject"
    ]
  }
}
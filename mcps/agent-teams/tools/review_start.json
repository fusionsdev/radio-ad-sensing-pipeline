{
  "name": "review_start",
  "description": "Signal that reviewer is beginning to review a task (moves to REVIEW column)",
  "inputSchema": {
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "object",
    "properties": {
      "teamName": {
        "type": "string",
        "minLength": 1
      },
      "claudeDir": {
        "type": "string",
        "minLength": 1
      },
      "taskId": {
        "type": "string",
        "minLength": 1
      },
      "from": {
        "type": "string"
      }
    },
    "required": [
      "teamName",
      "taskId"
    ]
  }
}
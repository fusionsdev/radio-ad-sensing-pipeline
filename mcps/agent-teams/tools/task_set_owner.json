{
  "name": "task_set_owner",
  "description": "Assign, reassign, or clear task owner",
  "inputSchema": {
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "object",
    "properties": {
      "teamName": {
        "type": "string",
        "minLength": 1
      },
      "claudeDir": {
        "type": "string",
        "minLength": 1
      },
      "taskId": {
        "type": "string",
        "minLength": 1
      },
      "owner": {
        "anyOf": [
          {
            "type": "string"
          },
          {
            "type": "null"
          }
        ]
      },
      "actor": {
        "type": "string"
      }
    },
    "required": [
      "teamName",
      "taskId",
      "owner"
    ]
  }
}
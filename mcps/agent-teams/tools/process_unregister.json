{
  "name": "process_unregister",
  "description": "Unregister a previously registered background service while keeping teammate-agent state separate.",
  "inputSchema": {
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "object",
    "properties": {
      "teamName": {
        "type": "string",
        "minLength": 1
      },
      "claudeDir": {
        "type": "string",
        "minLength": 1
      },
      "pid": {
        "type": "integer",
        "exclusiveMinimum": 0,
        "maximum": 9007199254740991
      }
    },
    "required": [
      "teamName",
      "pid"
    ]
  }
}
{
  "name": "task_set_status",
  "description": "Set task work status",
  "inputSchema": {
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "object",
    "properties": {
      "teamName": {
        "type": "string",
        "minLength": 1
      },
      "claudeDir": {
        "type": "string",
        "minLength": 1
      },
      "taskId": {
        "type": "string",
        "minLength": 1
      },
      "status": {
        "type": "string",
        "enum": [
          "pending",
          "in_progress",
          "completed",
          "deleted"
        ]
      },
      "actor": {
        "type": "string"
      }
    },
    "required": [
      "teamName",
      "taskId",
      "status"
    ]
  }
}
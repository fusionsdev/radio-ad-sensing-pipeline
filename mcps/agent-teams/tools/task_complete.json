    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "object",
    "properties": {
      "teamName": {
        "type": "string",
        "minLength": 1
      },
      "claudeDir": {
        "type": "string",
        "minLength": 1
      },
      "taskId": {
        "type": "string",
        "minLength": 1
      },
      "actor": {
        "type": "string"
      }
    },
    "required": [

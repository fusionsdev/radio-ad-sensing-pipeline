{
  "name": "member_briefing",
  "description": "Get bootstrap briefing for a team member",
  "inputSchema": {
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "object",
    "properties": {
      "teamName": {
        "type": "string",
        "minLength": 1
      },
      "claudeDir": {
        "type": "string",
        "minLength": 1
      },
      "memberName": {
        "type": "string",
        "minLength": 1
      },
      "runtimeProvider": {
        "type": "string",
        "enum": [
          "native",
          "opencode",
          "codex"
        ]
      },
      "includeActiveProcesses": {
        "type": "boolean"
      }
    },
    "required": [
      "teamName",
      "memberName"
    ]
  }
}
{
  "name": "team_launch",
  "description": "Launch a provisioned team via the desktop runtime",
  "inputSchema": {
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "object",
    "properties": {
      "teamName": {
        "type": "string",
        "minLength": 1
      },
      "claudeDir": {
        "type": "string",
        "minLength": 1
      },
      "controlUrl": {
        "type": "string"
      },
      "waitTimeoutMs": {
        "type": "integer",
        "minimum": 1000,
        "maximum": 600000
      },
      "cwd": {
        "type": "string",
        "minLength": 1
      },
      "prompt": {
        "type": "string",
        "minLength": 1
      },
      "model": {
        "type": "string",
        "minLength": 1
      },
      "effort": {
        "type": "string",
        "enum": [
          "low",
          "medium",
          "high"
        ]
      },
      "clearContext": {
        "type": "boolean"
      },
      "skipPermissions": {
        "type": "boolean"
      },
      "worktree": {
        "type": "string",
        "minLength": 1
      },
      "extraCliArgs": {
        "type": "string",
        "minLength": 1
      },
      "waitForReady": {
        "type": "boolean"
      }
    },
    "required": [
      "teamName",
      "cwd"
    ]
  }
}
{
  "name": "runtime_heartbeat",
  "description": "Refresh OpenCode member runtime liveness in the app-owned launch state",
  "inputSchema": {
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "object",
    "properties": {
      "teamName": {
        "type": "string",
        "minLength": 1
      },
      "claudeDir": {
        "type": "string",
        "minLength": 1
      },
      "controlUrl": {
        "type": "string"
      },
      "waitTimeoutMs": {
        "type": "integer",
        "minimum": 1000,
        "maximum": 600000
      },
      "runId": {
        "type": "string",
        "minLength": 1
      },
      "memberName": {
        "type": "string",
        "minLength": 1
      },
      "runtimeSessionId": {
        "type": "string",
        "minLength": 1
      },
      "observedAt": {
        "type": "string",
        "minLength": 1
      },
      "status": {
        "type": "string",
        "enum": [
          "alive",
          "idle",
          "busy"
        ]
      },
      "metadata": {
        "type": "object",
        "propertyNames": {
          "type": "string"
        },
        "additionalProperties": {}
      }
    },
    "required": [
      "teamName",
      "runId",
      "memberName",
      "runtimeSessionId"
    ]
  }
}
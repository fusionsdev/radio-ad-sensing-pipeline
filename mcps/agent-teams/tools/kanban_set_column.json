{
  "name": "kanban_set_column",
  "description": "Repair the kanban overlay for a task that is already in review or approved. Use review_request/review_approve for lifecycle transitions.",
  "inputSchema": {
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "object",
    "properties": {
      "teamName": {
        "type": "string",
        "minLength": 1
      },
      "claudeDir": {
        "type": "string",
        "minLength": 1
      },
      "taskId": {
        "type": "string",
        "minLength": 1
      },
      "column": {
        "type": "string",
        "enum": [
          "review",
          "approved"
        ]
      }
    },
    "required": [
      "teamName",
      "taskId",
      "column"
    ]
  }
}
{
  "name": "runtime_task_event",
  "description": "Record an idempotent OpenCode runtime task event for app-side attribution",
  "inputSchema": {
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "object",
    "properties": {
      "teamName": {
        "type": "string",
        "minLength": 1
      },
      "claudeDir": {
        "type": "string",
        "minLength": 1
      },
      "controlUrl": {
        "type": "string"
      },
      "waitTimeoutMs": {
        "type": "integer",
        "minimum": 1000,
        "maximum": 600000
      },
      "idempotencyKey": {
        "type": "string",
        "minLength": 1
      },
      "runId": {
        "type": "string",
        "minLength": 1
      },
      "memberName": {
        "type": "string",
        "minLength": 1
      },
      "runtimeSessionId": {
        "type": "string",
        "minLength": 1
      },
      "taskId": {
        "type": "string",
        "minLength": 1
      },
      "event": {
        "type": "string",
        "minLength": 1
      },
      "createdAt": {
        "type": "string",
        "minLength": 1
      },
      "summary": {
        "type": "string"
      },
      "metadata": {
        "type": "object",
        "propertyNames": {
          "type": "string"
        },
        "additionalProperties": {}
      }
    },
    "required": [
      "teamName",
      "idempotencyKey",
      "runId",
      "memberName",
      "taskId",
      "event"
    ]
  }
}
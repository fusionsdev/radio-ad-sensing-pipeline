{
  "name": "cross_team_send",
  "description": "Send a message to another team. The message is delivered to the target team lead inbox.",
  "inputSchema": {
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "object",
    "properties": {
      "teamName": {
        "type": "string",
        "minLength": 1
      },
      "claudeDir": {
        "type": "string",
        "minLength": 1
      },
      "toTeam": {
        "type": "string",
        "minLength": 1
      },
      "text": {
        "type": "string",
        "minLength": 1
      },
      "fromMember": {
        "type": "string"
      },
      "summary": {
        "type": "string"
      },
      "conversationId": {
        "type": "string"
      },
      "replyToConversationId": {
        "type": "string"
      },
      "taskRefs": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "taskId": {
              "type": "string",
              "minLength": 1
            },
            "displayId": {
              "type": "string",
              "minLength": 1
            },
            "teamName": {
              "type": "string",
              "minLength": 1
            }
          },
          "required": [
            "taskId",
            "displayId",
            "teamName"
          ]
        }
      },
      "chainDepth": {
        "type": "integer",
        "minimum": 0,
        "maximum": 9007199254740991
      }
    },
    "required": [
      "teamName",
      "toTeam",
      "text"
    ]
  }
}
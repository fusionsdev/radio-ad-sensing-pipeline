{
  "name": "task_set_clarification",
  "description": "Set or clear task clarification state",
  "inputSchema": {
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "object",
    "properties": {
      "teamName": {
        "type": "string",
        "minLength": 1
      },
      "claudeDir": {
        "type": "string",
        "minLength": 1
      },
      "taskId": {
        "type": "string",
        "minLength": 1
      },
      "value": {
        "type": "string",
        "enum": [
          "lead",
          "user",
          "clear"
        ]
      }
    },
    "required": [
      "teamName",
      "taskId",
      "value"
    ]
  }
}